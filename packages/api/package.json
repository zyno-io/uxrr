    "scripts": {
        "clean": "tsf-dev clean",
        "build": "tsf-dev build",
        "dev": "tsf-dev run -- server:start",
        "start": "node . server:start",
        "migrate": "tsf-dev migrate",
        "test": "tsf-dev test $(find tests -name '*.spec.ts' -not -path '*/integration/*' | sort)",
        "test:int": "UXRR_DEV_MODE=true tsf-dev test tests/integration/",
        "test:all": "tsf-dev test",
