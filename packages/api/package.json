        "jose": "^6.2.3",
        "mime-types": "^3.0.2"
    },
    "devDependencies": {
        "@types/lodash": "^4.17.24",
        "@types/mime-types": "^3.0.1",
        "@types/node": "^26.1.1",
        "patch-package": "^8.0.1",
