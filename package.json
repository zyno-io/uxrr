{
    "name": "uxrr",
    "version": "0.1.2",
    "private": true,
    "license": "SEE LICENSE IN LICENSE",
    "workspaces": [
        "packages/*"
    ],
    "scripts": {
        "build": "yarn workspaces foreach -At run build",
        "build:client": "yarn workspace @zyno-io/uxrr-client build",
        "build:api": "yarn workspace @zyno-io/uxrr-api build",
        "build:ui": "yarn workspace @zyno-io/uxrr-ui build",
        "dev:api": "yarn workspace @zyno-io/uxrr-api dev",
        "dev:ui": "yarn workspace @zyno-io/uxrr-ui dev",
        "docs:dev": "vitepress dev docs",
        "docs:build": "vitepress build docs",
        "docs:preview": "vitepress preview docs",
        "migrate": "yarn workspace @zyno-io/uxrr-api migrate",
        "test": "yarn workspace @zyno-io/uxrr-api test",
        "test:e2e": "scripts/test-e2e.sh",
        "test:e2e:vrt": "scripts/test-e2e.sh vrt",
        "test:e2e:live": "scripts/test-e2e.sh live",
        "clean": "yarn workspaces foreach -A run clean",
        "format": "npx oxlint --fix --fix-suggestions --fix-dangerously && oxfmt"
    },
    "devDependencies": {
        "lefthook": "^2.1.10",
        "oxfmt": "^0.58.0",
        "oxlint": "^1.73.0",
        "typescript": "~6.0",
        "vitepress": "^1.6.4"
    },
    "resolutions": {
        "@rrweb/packer": "2.0.0-alpha.20",
        "@rrweb/replay": "2.0.0-alpha.20",
        "@rrweb/rrweb-plugin-console-record": "2.0.0-alpha.20",
        "@rrweb/types": "2.0.0-alpha.20",
        "@rrweb/utils": "2.0.0-alpha.20",
        "rrdom": "2.0.0-alpha.20",
        "rrweb": "2.0.0-alpha.20",
        "rrweb-player": "2.0.0-alpha.20",
        "rrweb-snapshot": "2.0.0-alpha.20"
    },
    "packageManager": "yarn@4.17.1"
}
